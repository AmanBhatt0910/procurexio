# Environment Variables Template
# 
# SECURITY: Never commit actual secrets to this file. Use .env.local for development.
# This file shows the REQUIRED environment variables and their format.
#
# Copy this to .env.local and fill in actual values from your secret manager.

# ── Database ──────────────────────────────────────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=procurement_db

# ── JWT / Authentication (Generate a strong random key, min 32 chars)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Cookie Security
# Set to "false" for HTTP-only deployments (local dev)
# Set to "true" to force Secure flag (production)
COOKIE_SECURE=

# ── Email Service (Resend)
RESEND_API_KEY=
INVITE_FROM_EMAIL=no-reply@procurexio.com

# ── Application
NEXT_PUBLIC_APP_NAME=Procurexio
NEXT_PUBLIC_BASE_URL=

# ── Google OAuth (Optional - for "Login with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ── Cron Jobs (Use strong random tokens for production)
CRON_SECRET=
RFQ_CLOSE_CRON_TOKEN=
RFQ_REMINDER_CRON_TOKEN=

# ── Logging (Optional)
LOG_LEVEL=info  # debug, info, warn, error

# ── Node Environment
NODE_ENV=development  # development, production
