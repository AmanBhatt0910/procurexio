# ============================================================
# Procurexio — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=procurement_db

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cookie security: set to "false" for HTTP-only deployments,
# "true" to force Secure in all cases. Leave unset to auto-detect.
# COOKIE_SECURE=false

# ── Super Admin Seed (used by `npm run seed:superadmin`) ─────
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@1234

# ── Login Security ───────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION_MINUTES=30

# ── Password Reset ───────────────────────────────────────────
PASSWORD_RESET_EXPIRY_HOURS=24

# ── Invitations ──────────────────────────────────────────────
INVITATION_EXPIRY_DAYS=7

# ── Currency ─────────────────────────────────────────────────
DEFAULT_CURRENCY=USD

# ── OAuth (Google) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
OAUTH_STATE_EXPIRY_SECONDS=600

# ── Email / SMTP ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@example.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_USER_MAX=1000
RATE_LIMIT_USER_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=60
RATE_LIMIT_IP_WINDOW_MS=60000

# ── Notifications ────────────────────────────────────────────
NOTIFICATION_POLL_MS=30000

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Cron Job Tokens ──────────────────────────────────────────
# Secret tokens used to authenticate scheduled cron job calls.
# Generate a strong random value (e.g. openssl rand -hex 32).
RFQ_REMINDER_CRON_TOKEN=replace_with_a_long_random_secret
RFQ_CLOSE_CRON_TOKEN=replace_with_a_long_random_secret
