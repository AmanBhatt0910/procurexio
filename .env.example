# =============================================================================
# Procurexio — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit your actual .env.local to source control.
#
# All variables marked [REQUIRED] must be set or the application will
# fail to start in production (NODE_ENV=production).
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────

# Public base URL (used in emails, OAuth redirects, etc.)
# [REQUIRED]
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Application display name (used in emails and UI)
NEXT_PUBLIC_APP_NAME=Procurexio

# ── Authentication ────────────────────────────────────────────────────────────

# JWT signing secret — use a long, random string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# [REQUIRED]
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# ── Database ──────────────────────────────────────────────────────────────────

# MySQL / PlanetScale connection details
# [REQUIRED]
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=procurement_db

# ── Email (Resend) ────────────────────────────────────────────────────────────

# Resend API key — https://resend.com
# [REQUIRED for email features]
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address for transactional emails
INVITE_FROM_EMAIL=Procurexio <no-reply@procurexio.com>

# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
# Defaults to 'info' in production, 'debug' in development
LOG_LEVEL=info

# Optional: write logs to a file in addition to stdout
# LOG_FILE_PATH=/var/log/procurexio/app.log

# ── Security ─────────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# ── Cookie security ───────────────────────────────────────────────────────────

# Controls the Secure attribute on the auth cookie.
#
# IMPORTANT — read this if login redirects you back to the login page:
#
# "auto" (default — omit the variable):
#   Detects HTTPS from the X-Forwarded-Proto / X-Forwarded-Ssl header set by
#   your reverse proxy (Nginx, Cloudflare, AWS ALB).  If no proxy header is
#   present, falls back to NODE_ENV: production = Secure, development = no Secure.
#
# COOKIE_SECURE=true   — always set Secure (use when terminating HTTPS in Nginx
#                        AND the proxy forwards X-Forwarded-Proto correctly)
#
# COOKIE_SECURE=false  — never set Secure (required for HTTP-only deployments;
#                        the browser will NOT send a Secure cookie over HTTP,
#                        which causes an infinite login-redirect loop)
#
# For Windows Server + Nginx without HTTPS, set:
#   COOKIE_SECURE=false
#
# For Windows Server + Nginx WITH HTTPS and proxy_set_header X-Forwarded-Proto $scheme,
# you can leave this unset (auto-detection will handle it).
#
# COOKIE_SECURE=false
